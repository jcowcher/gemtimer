{
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ]; then exit 1; else exit 0; fi",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "elementarytimer.com"
        }
      ],
      "destination": "https://gemtimer.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.elementarytimer.com"
        }
      ],
      "destination": "https://gemtimer.com/:path*",
      "permanent": true
    }
  ]
}
