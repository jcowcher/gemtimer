{
  "git": {
    "deploymentEnabled": {
      "dev": false
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "elementarytimer.com"
        }
      ],
      "destination": "https://gemtimer.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.elementarytimer.com"
        }
      ],
      "destination": "https://gemtimer.com/:path*",
      "permanent": true
    }
  ]
}
